{
  "name": "pdf-to-bloom-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "A monorepo for PDF to Bloom conversion tools",
  "scripts": {
    "build": "vp run -r build",
    "build:lib": "vp run -F @pdf-to-bloom/lib build",
    "build:cli": "vp run -F @pdf-to-bloom/cli build",
    "test": "vp test run",
    "test:watch": "vp test watch",
    "test:lib": "vp test run packages/lib",
    "test:lib:watch": "vp test watch packages/lib",
    "test:strict": "vp test run",
    "test:manual-llm": "vp run -F @pdf-to-bloom/lib test packages/lib/src/2-llm/llmMarkdown.manual.test.ts",
    "dev": "vp run -r --parallel dev",
    "dev:lib": "vp run -F @pdf-to-bloom/lib dev",
    "dev:cli": "vp run -F @pdf-to-bloom/cli dev",
    "cli": "node packages/cli/dist/index.js",
    "format": "vp fmt",
    "lint": "vp lint",
    "check": "vp check",
    "test:md-to-tagged": "pnpm run build:lib && pnpm run build:cli && node packages/cli/dist/index.js test-inputs/testme.md --target tagged",
    "test:children": "pnpm run cli test-inputs/children-come.pdf --collection 'Apalɨ Books'",
    "test:children-stage3": "pnpm run cli \"C:\\Users\\hatto\\OneDrive\\Documents\\Bloom\\Apalɨ Books\\children-come\\children-come.raw-llm.md\" --collection 'Apalɨ Books'",
    "prepare": "vp config"
  },
  "dependencies": {
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.5.1"
}
