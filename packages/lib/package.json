    "exiftool-vendored": "^35.20.0",
    "js-yaml": "^4.1.0",
    "pdfjs-dist": "^5.3.93",
    "sharp": "^0.34.3",
    "unpdf": "^1.1.0",
    "zod": "^3.25.33"
  },
  "devDependencies": {
    "@types/escape-html": "^1.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.24",
    "typescript": "^5.8.3",
