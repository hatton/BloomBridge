{
  "cSpell.words": [
    "openrouter",
    "oxfmt",
    "oxlint",
    "testme",
    "vite",
    "viteplus",
    "vitest",
    "voidzero"
  ],
  "workbench.colorCustomizations": {
    "statusBar.background": "#007fff",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#3399ff",
    "statusBarItem.remoteBackground": "#007fff",
    "statusBarItem.remoteForeground": "#e7e7e7"
  },
  "peacock.color": "#007fff",
  // Format on save with the Vite+ / oxc formatter (vp fmt), reading config
  // from vite.config.ts so the editor matches the pre-commit hook exactly.
  // Requires the recommended "VoidZero.vite-plus-extension-pack" extension.
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "oxc.fmt.configPath": "./vite.config.ts",
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json5]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
